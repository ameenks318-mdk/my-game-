rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'xp', 'coins', 'level']) &&
             data.keys().size() <= 10 && // Bounded keys
             data.userId is string && data.userId == request.auth.uid &&
             data.xp is number && data.xp >= 0 &&
             data.coins is number && data.coins >= 0 &&
             data.level is number && data.level >= 1;
    }

    // --- Collections ---
    
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
        request.resource.data.userId == resource.data.userId; // Immutable ID
    }

    match /leaderboard/{userId} {
      // Publicly readable for global competition
      allow get, list: if isSignedIn();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if isOwner(userId);
    }
  }
}
